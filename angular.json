{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "tools-ecosystem": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/manifest.json"
            ],
            "styles": [
              "src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "1024kB",
                  "maximumError": "1024kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "tools-ecosystem:build:production"
            },
            "development": {
              "buildTarget": "tools-ecosystem:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        },
        "server": {
          "builder": "@angular/build:application",
          "options": {
            "assets":[
              {
                "glob": "**/*",
                "input": "public",
                "output": "/"
              }
            ],
            "server": "src/main.server.ts",
            "prerender": false,
            "ssr": {
              "entry": "server.ts"
            },
            "outputPath": "dist/tools-ecosystem",
            "tsConfig": "tsconfig.server.json",
            "externalDependencies": [
              "canvas",
              "pdfjs-dist"
            ]
          },
          "configurations": {
            "production": {
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve-ssr": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "tools-ecosystem:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "tools-ecosystem:build:production"
            },
            "development": {
              "buildTarget": "tools-ecosystem:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "prerender": {
          "builder": "@angular/build:prerender",
          "options": {
            "browserTarget": "tools-ecosystem:build:production",
            "serverTarget": "tools-ecosystem:server:production",
            "routes": ["/"]
          },
          "configurations": {
            "development": {
              "browserTarget": "tools-ecosystem:build:development",
              "serverTarget": "tools-ecosystem:server:development"
            }
          }
        }
      }
    }
  }
}
