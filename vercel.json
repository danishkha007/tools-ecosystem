{
  "version": 2,
  "buildCommand": "npm run build:ssr",
  "devCommand": "ng serve",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "dist/tools-ecosystem/browser",
  "builds": [
    {
      "src": "api/server/index.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/server"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}