{
  "version": 2,
  "buildCommand": "npm run build:ssr",
  "devCommand": "ng serve",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "dist/tools-ecosystem/browser",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/server"
    }
  ],
  "functions": {
    "api/server/index": {
      "maxDuration": 10,
      "memory": 2048,
      "includeFiles":"dist/tools-ecosystem/server/**"
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}