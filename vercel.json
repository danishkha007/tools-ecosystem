{
  "version": 2,
  "buildCommand": "npm ci && npm run build:ssr",
  "devCommand": "ng serve",
  "installCommand": "npm ci",
  "outputDirectory": "dist/tools-ecosystem/browser",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/server"
    }
  ],
  "functions": {
    "dist/tools-ecosystem/server/server.mjs": {
      "name": "Server Function",
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/server",
      "dest": "/api/server"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
