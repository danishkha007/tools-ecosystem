{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./",
    "rootDir": "./",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "declaration": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["**/*.ts", "server/index.ts"],
  "exclude": ["node_modules"]
}
